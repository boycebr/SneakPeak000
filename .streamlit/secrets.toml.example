# SneakPeak — Streamlit Cloud Secrets
# Copy this to secrets.toml (or paste into Streamlit Cloud dashboard)
# See: https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/secrets-management

# ── Supabase ──
SUPABASE_URL = "https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY = "eyJ..."
SUPABASE_SERVICE_KEY = "eyJ..."

# ── Google Cloud Vision (face detection) ──
GOOGLE_CLOUD_API_KEY = "AIza..."

# ── Azure Face API (fallback face detection — optional) ──
AZURE_FACE_API_KEY = ""
AZURE_FACE_ENDPOINT = ""

# ── AWS (optional — unused in current MVP) ──
AWS_ACCESS_KEY_ID = ""
AWS_SECRET_ACCESS_KEY = ""
AWS_REGION = "us-east-2"

# ── App settings ──
APP_ENV = "production"
DEBUG = "false"
MAX_UPLOAD_SIZE_MB = "100"
VIDEO_MIN_DURATION = "5"
VIDEO_MAX_DURATION = "60"
